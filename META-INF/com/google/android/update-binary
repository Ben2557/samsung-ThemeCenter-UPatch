#!/sbin/sh
##########################################################################################
# Standard Magisk/KernelSU/APatch Module Installer
# Compatible with: Magisk v19+, KernelSU, APatch
##########################################################################################

SKIPUNZIP=1

# ── Environment setup ─────────────────────────────────────────────────────────

# OUTFD / ZIPFILE / TMPDIR are set by the root manager when calling this script
# as: update-binary <OUTFD_NUM> <unused> <ZIPFILE>
# Fallback for manual or unusual invocations:
[ -z "$OUTFD" ]   && OUTFD="$2"
[ -z "$ZIPFILE" ] && ZIPFILE="$3"
[ -z "$TMPDIR" ]  && TMPDIR=/dev/tmp
[ -z "$NVBASE" ]  && NVBASE=/data/adb

mkdir -p "$TMPDIR"

ui_print() {
  if [ -n "$OUTFD" ] && [ -e /proc/self/fd/$OUTFD ]; then
    echo "ui_print $1" >> /proc/self/fd/$OUTFD
    echo "ui_print"    >> /proc/self/fd/$OUTFD
  else
    echo "$1"
  fi
}

abort() {
  ui_print "$*"
  exit 1
}

# ── Locate util_functions.sh (Magisk / KernelSU / APatch) ─────────────────────

UTIL_FUNCTIONS=""
for candidate in \
    /data/adb/magisk/util_functions.sh \
    /data/adb/ksu/util_functions.sh \
    /data/adb/ap/util_functions.sh; do
  if [ -f "$candidate" ]; then
    UTIL_FUNCTIONS="$candidate"
    break
  fi
done

[ -z "$UTIL_FUNCTIONS" ] && \
  abort "! util_functions.sh not found. Please use Magisk v19+, KernelSU or APatch."

. "$UTIL_FUNCTIONS"

# ── Delegate to the standard module installation flow ─────────────────────────

install_module
exit 0
