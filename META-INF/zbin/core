       ;;
       -o|-output)
       move="$2"
       shift 2
       ;;
       -c|-command)
       command="$2"
       shift 2
       ;;
       -f|-framework)
       fw="$2"
       shift 2
       ;;
       *)   
       restore+=("$1")
       shift
       ;;
   esac
   done
   set -- "${restore[@]}"
   if [ ! -e /system/build.prop ]; then auto_mount_partitions; fi
